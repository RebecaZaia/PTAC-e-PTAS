generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model click_tracking {
  id            BigInt      @id @default(autoincrement())
  short_link_id BigInt
  clicked_at    DateTime?   @default(now()) @db.Timestamptz(6)
  referrer      String?
  user_agent    String?
  short_links   short_links @relation(fields: [short_link_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model plans {
  id         BigInt  @id @default(autoincrement())
  name       String
  price      Decimal @db.Decimal(10, 2)
  max_links  Int
  max_clicks Int
  users      users[]
}

model reports {
  id           BigInt    @id @default(autoincrement())
  user_id      BigInt
  report_type  String
  generated_at DateTime? @default(now()) @db.Timestamptz(6)
  data         Json?
  users        users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model short_links {
  id             BigInt           @id @default(autoincrement())
  user_id        BigInt
  original_url   String
  short_code     String           @unique
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  click_tracking click_tracking[]
  users          users            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id            BigInt        @id @default(autoincrement())
  email         String        @unique
  password_hash String
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  plan_id       BigInt?
  reports       reports[]
  short_links   short_links[]
  plans         plans?        @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
